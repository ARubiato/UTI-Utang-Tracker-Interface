generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Person {
  id        String     @id @default(cuid())
  name      String
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  debtItems DebtItem[]
}

model DebtItem {
  id             String    @id @default(cuid())
  personId       String
  itemName       String
  totalAmount    Float
  monthlyPayment Float
  months         Int
  startDate      DateTime  @default(now())
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  person         Person    @relation(fields: [personId], references: [id], onDelete: Cascade)
  payments       Payment[]
}

model Payment {
  id         String   @id @default(cuid())
  debtItemId String
  amount     Float
  paidAt     DateTime @default(now())
  createdAt  DateTime @default(now())
  debtItem   DebtItem @relation(fields: [debtItemId], references: [id], onDelete: Cascade)
}
